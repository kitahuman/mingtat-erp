# ══════════════════════════════════════════════════════════════
# MingTat ERP Backend — Environment Variables Example
# 複製此檔案為 .env 並填入實際值，切勿將 .env 提交至版本控制
# ══════════════════════════════════════════════════════════════

# ── 資料庫 ─────────────────────────────────────────────────────
# PostgreSQL 連線字串（必填）
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# ── 應用程式設定 ───────────────────────────────────────────────
# 伺服器監聽埠號（預設 3001）
PORT=3001

# 允許跨域請求的來源，多個來源以逗號分隔
# 例：https://your-frontend.example.com,http://localhost:3000
CORS_ORIGIN=

# 後端公開 URL（用於生成對外連結）
BACKEND_PUBLIC_URL=

# ── JWT 認證（必填）────────────────────────────────────────────
# JWT 簽名密鑰，請使用強隨機字串（至少 64 字元）
# 生成方式：openssl rand -hex 32
JWT_SECRET=

# JWT Token 有效期（預設 7d）
JWT_EXPIRES_IN=7d

# ── 管理員初始密碼（必填，僅首次啟動時使用）──────────────────
# 系統首次啟動時建立 admin 帳號所使用的密碼
# 建立後請立即透過系統介面修改密碼
ADMIN_INITIAL_PASSWORD=

# ── WhatsApp Webhook 安全驗證（必填）──────────────────────────
# WhatsApp Bot 傳送 Webhook 請求時使用的 Secret
# 請使用強隨機字串（至少 32 字元）
WHATSAPP_WEBHOOK_SECRET=

# WhatsApp 打卡功能 Webhook Secret
WHATSAPP_CLOCKIN_SECRET=

# ── OpenAI / AI 功能 ───────────────────────────────────────────
# OpenAI API 金鑰（用於 AI 聊天功能）
OPENAI_API_KEY=

# 自定義 OpenAI API Base URL（可選，用於使用代理或相容 API）
OPENAI_BASE_URL=

# ── 代理設定（可選）────────────────────────────────────────────
# SOCKS5 代理（用於繞過地區限制存取 OpenAI API）
# 格式：socks5://USER:PASSWORD@HOST:PORT
SOCKS_PROXY_URL=

# HTTP/HTTPS 代理（可選）
HTTP_PROXY=
HTTPS_PROXY=
