generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// Users
// ══════════════════════════════════════════════════════════════

model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String
  displayName String    @default("") @map("display_name")
  role        String    @default("worker")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  email       String?
  phone       String?
  department  String?
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz
  createdBy   Int?      @map("created_by")

  work_logs   WorkLog[]
  employee_id Int?      @unique @map("employee_id")
  employee    Employee? @relation(fields: [employee_id], references: [id])

  @@map("users")
}

// ══════════════════════════════════════════════════════════════
// Companies
// ══════════════════════════════════════════════════════════════

model Company {
  id              Int      @id @default(autoincrement())
  name            String
  name_en         String?
  company_type    String   @default("internal")
  internal_prefix String?  @unique
  contact_person  String?
  phone           String?
  address         String?
  description     String?  @db.Text
  status          String   @default("active")
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  employees                Employee[]
  vehicles                 Vehicle[]
  machinery                Machinery[]
  employee_transfers_from  EmployeeTransfer[]  @relation("transfer_from_company")
  employee_transfers_to    EmployeeTransfer[]  @relation("transfer_to_company")
  vehicle_transfers_from   VehicleTransfer[]   @relation("vehicle_transfer_from")
  vehicle_transfers_to     VehicleTransfer[]   @relation("vehicle_transfer_to")
  machinery_transfers_from MachineryTransfer[] @relation("machinery_transfer_from")
  machinery_transfers_to   MachineryTransfer[] @relation("machinery_transfer_to")
  projects                 Project[]
  quotations               Quotation[]
  rate_cards               RateCard[]
  expenses                 Expense[]
  profiles                 CompanyProfile[]

  @@map("companies")
}

// ══════════════════════════════════════════════════════════════
// Company Profiles
// ══════════════════════════════════════════════════════════════

model CompanyProfile {
  id                        Int      @id @default(autoincrement())
  code                      String   @unique
  chinese_name              String
  english_name              String?
  registration_date         String?
  br_number                 String?
  br_expiry_date            String?
  cr_number                 String?
  registered_address        String?  @db.Text
  directors                 String?  @db.Text
  shareholders              String?  @db.Text
  secretary                 String?
  subcontractor_reg_no      String?
  subcontractor_reg_date    String?
  subcontractor_reg_expiry  String?
  subcontractor_work_types  String?  @db.Text
  subcontractor_specialties String?  @db.Text
  office_phone              String?
  office_fax                String?
  office_email              String?
  office_address            String?  @db.Text
  status                    String   @default("active")
  created_at                DateTime @default(now())
  updated_at                DateTime @default(now()) @updatedAt

  company_id Int?

  work_logs WorkLog[]
  payrolls  Payroll[]
  company   Company? @relation(fields: [company_id], references: [id])

  @@map("company_profiles")
}

// ══════════════════════════════════════════════════════════════
// Employees
// ══════════════════════════════════════════════════════════════

model Employee {
  id                          Int       @id @default(autoincrement())
  emp_code                    String?
  name_zh                     String
  name_en                     String?
  nickname                    String?
  role                        String    @default("worker")
  phone                       String?
  emergency_contact           String?
  join_date                   DateTime? @db.Date
  termination_date            DateTime? @db.Date
  termination_reason          String?   @db.Text
  bank_name                   String?
  bank_account                String?
  id_number                   String?
  date_of_birth               DateTime? @db.Date
  gender                      String?
  address                     String?   @db.Text
  frequent_vehicle            String?
  mpf_plan                    String?
  mpf_account_number          String?
  mpf_employment_date         DateTime? @db.Date
  mpf_old_employment_date     DateTime? @db.Date
  salary_notes                String?   @db.Text
  driving_license_no          String?
  driving_license_expiry      DateTime? @db.Date
  driving_license_class       String?
  approved_worker_cert_no     String?
  approved_worker_cert_expiry DateTime? @db.Date
  green_card_no               String?
  green_card_expiry           DateTime? @db.Date
  construction_card_no        String?
  construction_card_expiry    DateTime? @db.Date
  earth_mover_cert_no         String?
  earth_mover_cert_expiry     DateTime? @db.Date
  excavator_cert_no           String?
  excavator_cert_expiry       DateTime? @db.Date
  crane_operator_cert_no      String?
  crane_operator_cert_expiry  DateTime? @db.Date
  lorry_crane_cert_no         String?
  lorry_crane_cert_expiry     DateTime? @db.Date
  crawler_crane_cert_no       String?
  crawler_crane_cert_expiry   DateTime? @db.Date
  hydraulic_crane_cert_no     String?
  hydraulic_crane_cert_expiry DateTime? @db.Date
  airport_pass_no             String?
  airport_pass_expiry         DateTime? @db.Date
  gammon_pass_no              String?
  gammon_pass_expiry          DateTime? @db.Date
  leighton_pass_no            String?
  leighton_pass_expiry        DateTime? @db.Date
  confined_space_cert_no      String?
  confined_space_cert_expiry  DateTime? @db.Date
  compactor_cert_no           String?
  compactor_cert_expiry       DateTime? @db.Date
  slinging_silver_card_no     String?
  slinging_silver_card_expiry DateTime? @db.Date
  craft_test_cert_no          String?
  craft_test_cert_expiry      DateTime? @db.Date
  compaction_load_cert_no     String?
  compaction_load_cert_expiry DateTime? @db.Date
  aerial_platform_cert_no     String?
  aerial_platform_cert_expiry DateTime? @db.Date
  site_rigging_a12_cert_no              String?
  site_rigging_a12_cert_expiry           DateTime? @db.Date
  slinging_signaler_a12s_cert_no         String?
  slinging_signaler_a12s_cert_expiry     DateTime? @db.Date
  zero_injury_cert_no                    String?
  zero_injury_cert_expiry                DateTime? @db.Date
  designated_trade_safety_cert_no        String?
  designated_trade_safety_cert_expiry    DateTime? @db.Date
  small_loader_cert_expiry               DateTime? @db.Date
  safety_supervisor_cert_expiry          DateTime? @db.Date
  safe_work_procedure_cert_expiry        DateTime? @db.Date
  grinding_wheel_cert_expiry             DateTime? @db.Date
  ship_cargo_cert_expiry                 DateTime? @db.Date
  arc_welding_cert_expiry                DateTime? @db.Date
  gas_welding_cert_expiry                DateTime? @db.Date
  clp_safety_cert_expiry                 DateTime? @db.Date
  other_certificates          Json?     @db.JsonB
  cert_photos                 Json?     @db.JsonB  // { "driving_license": "url", "green_card": "url", ... }
  company_id                  Int
  status                      String    @default("active")
  notes                       String?   @db.Text
  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @default(now()) @updatedAt

  company         Company                 @relation(fields: [company_id], references: [id])
  salary_settings EmployeeSalarySetting[]
  transfers       EmployeeTransfer[]
  work_logs       WorkLog[]
  payrolls        Payroll[]
  expenses        Expense[]
  attendances     EmployeeAttendance[]
  leaves          EmployeeLeave[]
  user            User?

  @@map("employees")
}

model EmployeeSalarySetting {
  id                   Int      @id @default(autoincrement())
  employee_id          Int
  effective_date       DateTime @db.Date
  base_salary          Decimal  @default(0) @db.Decimal(10, 2)
  salary_type          String   @default("daily")
  allowance_night      Decimal  @default(0) @db.Decimal(10, 2)
  allowance_rent       Decimal  @default(0) @db.Decimal(10, 2)
  allowance_3runway    Decimal  @default(0) @db.Decimal(10, 2)
  ot_rate_standard     Decimal  @default(0) @db.Decimal(10, 2)
  allowance_well       Decimal  @default(0) @db.Decimal(10, 2)
  allowance_machine    Decimal  @default(0) @db.Decimal(10, 2)
  allowance_roller     Decimal  @default(0) @db.Decimal(10, 2)
  allowance_crane      Decimal  @default(0) @db.Decimal(10, 2)
  allowance_move_machine Decimal @default(0) @db.Decimal(10, 2)
  allowance_kwh_night  Decimal  @default(0) @db.Decimal(10, 2)
  allowance_mid_shift  Decimal  @default(0) @db.Decimal(10, 2)
  ot_1800_1900         Decimal  @default(0) @db.Decimal(10, 2)
  ot_1900_2000         Decimal  @default(0) @db.Decimal(10, 2)
  ot_0600_0700         Decimal  @default(0) @db.Decimal(10, 2)
  ot_0700_0800         Decimal  @default(0) @db.Decimal(10, 2)
  ot_mid_shift              Decimal  @default(0) @db.Decimal(10, 2)
  mid_shift_ot_allowance   Decimal  @default(0) @db.Decimal(10, 2)
  custom_allowances    Json?    @db.JsonB
  is_piece_rate        Boolean  @default(false)
  fleet_rate_card_id   Int?
  change_type          String?
  change_amount        Decimal? @db.Decimal(10, 2)
  notes                String?  @db.Text
  created_at           DateTime @default(now())

  employee Employee @relation(fields: [employee_id], references: [id])

  @@map("employee_salary_settings")
}

model EmployeeTransfer {
  id              Int      @id @default(autoincrement())
  employee_id     Int
  from_company_id Int
  to_company_id   Int
  transfer_date   DateTime @db.Date
  notes           String?  @db.Text
  created_at      DateTime @default(now())

  employee     Employee @relation(fields: [employee_id], references: [id])
  from_company Company  @relation("transfer_from_company", fields: [from_company_id], references: [id])
  to_company   Company  @relation("transfer_to_company", fields: [to_company_id], references: [id])

  @@map("employee_transfers")
}

// ══════════════════════════════════════════════════════════════
// Vehicles
// ══════════════════════════════════════════════════════════════

model Vehicle {
  id                Int       @id @default(autoincrement())
  plate_number      String
  vehicle_type      String?
  tonnage           Decimal?  @db.Decimal(5, 1)
  owner_company_id  Int
  insurance_expiry  DateTime? @db.Date
  permit_fee_expiry DateTime? @db.Date
  inspection_date   DateTime? @db.Date
  license_expiry    DateTime? @db.Date
  brand             String?
  model             String?
  status            String    @default("active")
  notes             String?   @db.Text
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  owner_company Company              @relation(fields: [owner_company_id], references: [id])
  plate_history VehiclePlateHistory[]
  transfers     VehicleTransfer[]

  @@map("vehicles")
}

model VehiclePlateHistory {
  id          Int      @id @default(autoincrement())
  vehicle_id  Int
  old_plate   String
  new_plate   String
  change_date DateTime @db.Date
  notes       String?  @db.Text
  created_at  DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicle_id], references: [id])

  @@map("vehicle_plate_history")
}

model VehicleTransfer {
  id              Int      @id @default(autoincrement())
  vehicle_id      Int
  from_company_id Int
  to_company_id   Int
  transfer_date   DateTime @db.Date
  notes           String?  @db.Text
  created_at      DateTime @default(now())

  vehicle      Vehicle @relation(fields: [vehicle_id], references: [id])
  from_company Company @relation("vehicle_transfer_from", fields: [from_company_id], references: [id])
  to_company   Company @relation("vehicle_transfer_to", fields: [to_company_id], references: [id])

  @@map("vehicle_transfers")
}

// ══════════════════════════════════════════════════════════════
// Machinery
// ══════════════════════════════════════════════════════════════

model Machinery {
  id                    Int       @id @default(autoincrement())
  machine_code          String
  machine_type          String?
  brand                 String?
  model                 String?
  tonnage               Decimal?  @db.Decimal(5, 1)
  serial_number         String?
  owner_company_id      Int
  inspection_cert_expiry DateTime? @db.Date
  insurance_expiry      DateTime? @db.Date
  status                String    @default("active")
  notes                 String?   @db.Text
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  owner_company Company            @relation(fields: [owner_company_id], references: [id])
  transfers     MachineryTransfer[]
  expenses      Expense[]

  @@map("machinery")
}

model MachineryTransfer {
  id              Int      @id @default(autoincrement())
  machinery_id    Int
  from_company_id Int
  to_company_id   Int
  transfer_date   DateTime @db.Date
  notes           String?  @db.Text
  created_at      DateTime @default(now())

  machinery    Machinery @relation(fields: [machinery_id], references: [id])
  from_company Company   @relation("machinery_transfer_from", fields: [from_company_id], references: [id])
  to_company   Company   @relation("machinery_transfer_to", fields: [to_company_id], references: [id])

  @@map("machinery_transfers")
}

// ══════════════════════════════════════════════════════════════
// Partners
// ══════════════════════════════════════════════════════════════

model Partner {
  id                  Int      @id @default(autoincrement())
  code                String?
  english_code        String?
  name                String
  name_en             String?
  partner_type        String
  category            String?
  contact_person      String?
  phone               String?
  mobile              String?
  email               String?
  fax                 String?
  address             String?  @db.Text
  description         String?  @db.Text
  notes               String?  @db.Text
  bank_name           String?
  bank_account        String?
  invoice_title       String?
  invoice_description String?  @db.Text
  quotation_remarks   String?  @db.Text
  invoice_remarks     String?  @db.Text
  is_subsidiary       Boolean  @default(false)
  subsidiaries        String?
  status              String   @default("active")
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  projects_as_client     Project[]       @relation("project_client")
  quotations_as_client   Quotation[]     @relation("quotation_client")
  rate_cards_as_client   RateCard[]      @relation("rate_card_client")
  fleet_rate_cards       FleetRateCard[]
  subcon_as_subcon       SubconRateCard[] @relation("subcon_partner")
  subcon_as_client       SubconRateCard[] @relation("subcon_client")
  work_logs              WorkLog[]
  subcon_fleet_drivers   SubcontractorFleetDriver[] @relation("subcon_fleet_drivers")
  expenses_as_supplier   Expense[] @relation("expense_supplier")
  expenses_as_client     Expense[] @relation("expense_client")
  contracts_as_client    Contract[] @relation("contract_client")

  @@map("partners")
}

// ══════════════════════════════════════════════════════════════
// Contracts (合約)
// ══════════════════════════════════════════════════════════════

model Contract {
  id              Int        @id @default(autoincrement())
  contract_no     String     @unique @db.VarChar(50)
  client_id       Int
  contract_name   String     @db.VarChar(200)
  description     String?
  sign_date       DateTime?  @db.Date
  start_date      DateTime?  @db.Date
  end_date        DateTime?  @db.Date
  original_amount Decimal    @default(0) @db.Decimal(14, 2)
  status          String     @default("active") @db.VarChar(20)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @default(now()) @updatedAt

  client          Partner    @relation("contract_client", fields: [client_id], references: [id], onDelete: Restrict)
  projects        Project[]
  expenses        Expense[]

  @@map("contracts")
}

// ══════════════════════════════════════════════════════════════
// Projects
// ══════════════════════════════════════════════════════════════

model Project {
  id           Int       @id @default(autoincrement())
  project_no   String    @unique
  project_name String
  company_id   Int
  client_id    Int?
  status       String    @default("pending")
  description  String?   @db.Text
  address      String?
  start_date   DateTime? @db.Date
  end_date     DateTime? @db.Date
  remarks      String?   @db.Text
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  contract_id  Int?

  company    Company    @relation(fields: [company_id], references: [id])
  client     Partner?   @relation("project_client", fields: [client_id], references: [id])
  contract   Contract?  @relation(fields: [contract_id], references: [id])
  quotations Quotation[]
  rate_cards RateCard[]
  expenses   Expense[]
  work_logs  WorkLog[]

  @@map("projects")
}

model ProjectSequence {
  id       Int    @id @default(autoincrement())
  prefix   String
  year     String
  last_seq Int    @default(0)

  @@unique([prefix, year])
  @@map("project_sequences")
}

// ══════════════════════════════════════════════════════════════
// Quotations
// ══════════════════════════════════════════════════════════════

model Quotation {
  id               Int      @id @default(autoincrement())
  quotation_no     String   @unique
  quotation_type   String   @default("project")
  company_id       Int
  client_id        Int?
  quotation_date   DateTime @db.Date
  contract_name    String?
  project_name     String?
  project_id       Int?
  total_amount     Decimal  @default(0) @db.Decimal(12, 2)
  status           String   @default("draft")
  validity_period  String?  @db.Text
  payment_terms    String?  @db.Text
  exclusions       String?  @db.Text
  external_remark  String?  @db.Text
  internal_remark  String?  @db.Text
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  company          Company         @relation(fields: [company_id], references: [id])
  client           Partner?        @relation("quotation_client", fields: [client_id], references: [id])
  project          Project?        @relation(fields: [project_id], references: [id])
  items            QuotationItem[]
  rate_cards       RateCard[]      @relation("rate_card_quotation")
  fleet_rate_cards FleetRateCard[]
  subcon_rate_cards SubconRateCard[]
  work_logs        WorkLog[]
  expenses         Expense[]

  @@map("quotations")
}

model QuotationItem {
  id               Int     @id @default(autoincrement())
  quotation_id     Int
  sort_order       Int     @default(1)
  item_name        String?
  item_description String? @db.Text
  quantity         Decimal @default(0) @db.Decimal(12, 4)
  unit             String?
  unit_price       Decimal @default(0) @db.Decimal(12, 2)
  amount           Decimal @default(0) @db.Decimal(12, 2)
  remarks          String? @db.Text

  quotation Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

model QuotationSequence {
  id         Int    @id @default(autoincrement())
  prefix     String
  year_month String
  last_seq   Int    @default(0)

  @@unique([prefix, year_month])
  @@map("quotation_sequences")
}

// ══════════════════════════════════════════════════════════════
// Rate Cards
// ══════════════════════════════════════════════════════════════

model RateCard {
  id                  Int       @id @default(autoincrement())
  company_id          Int
  client_id           Int
  contract_no         String?
  service_type        String?
  name                String?
  description         String?   @db.Text
  vehicle_tonnage     String?
  vehicle_type        String?
  origin              String?
  destination         String?
  day_rate            Decimal   @default(0) @db.Decimal(12, 2)
  day_unit            String?
  night_rate          Decimal   @default(0) @db.Decimal(12, 2)
  night_unit          String?
  mid_shift_rate      Decimal   @default(0) @db.Decimal(12, 2)
  mid_shift_unit      String?
  ot_rate             Decimal   @default(0) @db.Decimal(12, 2)
  ot_unit             String?
  effective_date      DateTime? @db.Date
  expiry_date         DateTime? @db.Date
  source_quotation_id Int?
  project_id          Int?
  remarks             String?   @db.Text
  rate_card_type      String    @default("rental")
  status              String    @default("active")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  company          Company    @relation(fields: [company_id], references: [id])
  client           Partner    @relation("rate_card_client", fields: [client_id], references: [id])
  source_quotation Quotation? @relation("rate_card_quotation", fields: [source_quotation_id], references: [id])
  project          Project?   @relation(fields: [project_id], references: [id])
  ot_rates         RateCardOtRate[]

  @@map("rate_cards")
}

model RateCardOtRate {
  id           Int     @id @default(autoincrement())
  rate_card_id Int
  time_slot    String
  rate         Decimal @default(0) @db.Decimal(12, 2)
  unit         String?

  rate_card RateCard @relation(fields: [rate_card_id], references: [id], onDelete: Cascade)

  @@map("rate_card_ot_rates")
}

// ══════════════════════════════════════════════════════════════
// Fleet Rate Cards
// ══════════════════════════════════════════════════════════════

model FleetRateCard {
  id                  Int      @id @default(autoincrement())
  client_id           Int?
  contract_no         String?
  vehicle_tonnage     String?
  vehicle_type        String?
  origin              String?
  destination         String?
  day_rate            Decimal  @default(0) @db.Decimal(12, 2)
  night_rate          Decimal  @default(0) @db.Decimal(12, 2)
  mid_shift_rate      Decimal  @default(0) @db.Decimal(12, 2)
  ot_rate             Decimal  @default(0) @db.Decimal(12, 2)
  unit                String?
  remarks             String?  @db.Text
  source_quotation_id Int?
  status              String   @default("active")
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  client           Partner?   @relation(fields: [client_id], references: [id])
  source_quotation Quotation? @relation(fields: [source_quotation_id], references: [id])

  @@map("fleet_rate_cards")
}

// ══════════════════════════════════════════════════════════════
// Subcon Rate Cards
// ══════════════════════════════════════════════════════════════

model SubconRateCard {
  id                  Int      @id @default(autoincrement())
  subcon_id           Int?
  plate_no            String?
  vehicle_tonnage     String?
  client_id           Int?
  contract_no         String?
  day_night           String?
  origin              String?
  destination         String?
  unit_price          Decimal  @default(0) @db.Decimal(12, 2)
  unit                String?
  exclude_fuel        Boolean  @default(false)
  remarks             String?  @db.Text
  source_quotation_id Int?
  status              String   @default("active")
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  subcontractor    Partner?   @relation("subcon_partner", fields: [subcon_id], references: [id])
  client           Partner?   @relation("subcon_client", fields: [client_id], references: [id])
  source_quotation Quotation? @relation(fields: [source_quotation_id], references: [id])

  @@map("subcon_rate_cards")
}

// ══════════════════════════════════════════════════════════════
// Custom Fields
// ══════════════════════════════════════════════════════════════

model CustomField {
  id               Int      @id @default(autoincrement())
  module           String
  field_name       String
  field_type       String
  options          String?  @db.Text
  is_required      Boolean  @default(false)
  has_expiry_alert Boolean  @default(false)
  sort_order       Int      @default(0)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  values CustomFieldValue[]

  @@map("custom_fields")
}

model CustomFieldValue {
  id              Int      @id @default(autoincrement())
  custom_field_id Int
  entity_id       Int
  module          String
  value           String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  custom_field CustomField @relation(fields: [custom_field_id], references: [id], onDelete: Cascade)

  @@map("custom_field_values")
}

// ══════════════════════════════════════════════════════════════
// Documents
// ══════════════════════════════════════════════════════════════

model Document {
  id          Int       @id @default(autoincrement())
  entity_type String
  entity_id   Int
  doc_type    String
  file_name   String
  file_path   String
  file_size   Int?
  mime_type   String?
  expiry_date DateTime? @db.Date
  notes       String?   @db.Text
  status      String    @default("active")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  @@map("documents")
}

// ══════════════════════════════════════════════════════════════
// Field Options
// ══════════════════════════════════════════════════════════════

model FieldOption {
  id         Int      @id @default(autoincrement())
  category   String
  label      String
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("field_options")
}

// ══════════════════════════════════════════════════════════════
// Work Logs
// ══════════════════════════════════════════════════════════════

model WorkLog {
  id                   Int       @id @default(autoincrement())
  publisher_id         Int?
  status               String    @default("editing")
  service_type         String?
  scheduled_date       DateTime? @db.Date
  company_profile_id   Int?
  client_id            Int?
  quotation_id         Int?
  employee_id          Int?
  machine_type         String?
  equipment_number     String?
  equipment_source     String?
  tonnage              String?
  day_night            String?
  start_location       String?   @db.Text
  start_time           String?
  end_location         String?   @db.Text
  end_time             String?
  quantity             Decimal?  @db.Decimal(10, 2)
  unit                 String?
  ot_quantity          Decimal?  @db.Decimal(10, 2)
  ot_unit              String?
  goods_quantity       Decimal?  @db.Decimal(10, 2)
  matched_rate_card_id Int?
  matched_rate         Decimal?  @db.Decimal(12, 2)
  matched_unit         String?
  matched_ot_rate      Decimal?  @db.Decimal(12, 2)
  price_match_status   String?
  price_match_note     String?   @db.Text
  receipt_no           String?
  work_order_no        String?
  is_confirmed              Boolean   @default(false)
  is_paid                   Boolean   @default(false)
  unverified_client_name    String?   // 員工自行輸入的未確認客戶名
  remarks                   String?   @db.Text
  created_at                DateTime  @default(now())
  updated_at                DateTime  @default(now()) @updatedAt

  project_id        Int?

  publisher         User?           @relation(fields: [publisher_id], references: [id])
  company_profile   CompanyProfile? @relation(fields: [company_profile_id], references: [id])
  client            Partner?        @relation(fields: [client_id], references: [id])
  quotation         Quotation?      @relation(fields: [quotation_id], references: [id])
  employee          Employee?       @relation(fields: [employee_id], references: [id])
  project           Project?        @relation(fields: [project_id], references: [id])
  payroll_work_logs PayrollWorkLog[]

  @@map("work_logs")
}

// ══════════════════════════════════════════════════════════════
// Payroll
// ══════════════════════════════════════════════════════════════

model Payroll {
  id                 Int       @id @default(autoincrement())
  period             String
  date_from          DateTime? @db.Date
  date_to            DateTime? @db.Date
  employee_id        Int
  company_profile_id Int?
  salary_type        String    @default("daily")
  base_rate          Decimal   @default(0) @db.Decimal(12, 2)
  work_days          Decimal   @default(0) @db.Decimal(10, 2)
  base_amount        Decimal   @default(0) @db.Decimal(12, 2)
  allowance_total    Decimal   @default(0) @db.Decimal(12, 2)
  ot_total           Decimal   @default(0) @db.Decimal(12, 2)
  commission_total   Decimal   @default(0) @db.Decimal(12, 2)
  mpf_deduction      Decimal   @default(0) @db.Decimal(12, 2)
  mpf_plan           String?
  mpf_employer       Decimal   @default(0) @db.Decimal(12, 2)
  adjustment_total   Decimal   @default(0) @db.Decimal(12, 2)
  net_amount         Decimal   @default(0) @db.Decimal(12, 2)
  status             String    @default("draft")
  payment_date       DateTime? @db.Date
  cheque_number      String?
  notes              String?   @db.Text
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now()) @updatedAt

  employee          Employee               @relation(fields: [employee_id], references: [id])
  company_profile   CompanyProfile?         @relation(fields: [company_profile_id], references: [id])
  items             PayrollItem[]
  payroll_work_logs PayrollWorkLog[]
  adjustments       PayrollAdjustment[]
  daily_allowances  PayrollDailyAllowance[]

  @@map("payrolls")
}

model PayrollItem {
  id         Int     @id @default(autoincrement())
  payroll_id Int
  item_type  String
  item_name  String
  unit_price Decimal @default(0) @db.Decimal(12, 2)
  quantity   Decimal @default(0) @db.Decimal(10, 2)
  amount     Decimal @default(0) @db.Decimal(12, 2)
  remarks    String? @db.Text
  sort_order Int     @default(0)

  payroll Payroll @relation(fields: [payroll_id], references: [id], onDelete: Cascade)

  @@map("payroll_items")
}

model PayrollWorkLog {
  id                   Int       @id @default(autoincrement())
  payroll_id           Int
  work_log_id          Int?
  service_type         String?
  scheduled_date       DateTime? @db.Date
  day_night            String?
  start_location       String?   @db.Text
  end_location         String?   @db.Text
  machine_type         String?
  tonnage              String?
  equipment_number     String?
  quantity             Decimal?  @db.Decimal(10, 2)
  unit                 String?
  ot_quantity          Decimal?  @db.Decimal(10, 2)
  ot_unit              String?
  remarks              String?   @db.Text
  matched_rate_card_id Int?
  matched_rate         Decimal?  @db.Decimal(12, 2)
  matched_unit         String?
  matched_ot_rate      Decimal?  @db.Decimal(12, 2)
  price_match_status   String?
  price_match_note     String?   @db.Text
  line_amount          Decimal   @default(0) @db.Decimal(12, 2)
  group_key            String?   @db.Text
  client_id            Int?
  client_name          String?
  company_profile_id   Int?
  company_profile_name String?
  quotation_id         Int?
  contract_no          String?
  is_modified          Boolean   @default(false)
  is_excluded          Boolean   @default(false)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  payroll  Payroll  @relation(fields: [payroll_id], references: [id], onDelete: Cascade)
  work_log WorkLog? @relation(fields: [work_log_id], references: [id], onDelete: SetNull)

  @@map("payroll_work_logs")
}

model PayrollAdjustment {
  id         Int      @id @default(autoincrement())
  payroll_id Int
  item_name  String
  amount     Decimal  @db.Decimal(12, 2)
  remarks    String?  @db.Text
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  payroll Payroll @relation(fields: [payroll_id], references: [id], onDelete: Cascade)

  @@map("payroll_adjustments")
}

model PayrollDailyAllowance {
  id             Int      @id @default(autoincrement())
  payroll_id     Int
  date           DateTime @db.Date
  allowance_key  String
  allowance_name String
  amount         Decimal  @default(0) @db.Decimal(12, 2)
  remarks        String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  payroll Payroll @relation(fields: [payroll_id], references: [id], onDelete: Cascade)

  @@map("payroll_daily_allowances")
}

// ══════════════════════════════════════════════════════════════
// Subcontractor Fleet Drivers
// ══════════════════════════════════════════════════════════════

model SubcontractorFleetDriver {
  id                   Int      @id @default(autoincrement())
  subcontractor_id     Int
  short_name           String?
  name_zh              String
  name_en              String?
  id_number            String?
  vehicle_type         String?
  plate_no             String?
  phone                String?
  date_of_birth        DateTime? @db.Date
  yellow_cert_no       String?
  red_cert_no          String?
  has_d_cert           Boolean   @default(false)
  is_cert_returned     Boolean   @default(false)
  address              String?   @db.Text
  status               String    @default("active")
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  subcontractor        Partner   @relation("subcon_fleet_drivers", fields: [subcontractor_id], references: [id])

  @@map("subcontractor_fleet_drivers")
}

// ══════════════════════════════════════════════════════════════
// Employee Attendance (員工打卡)
// ══════════════════════════════════════════════════════════════

model EmployeeAttendance {
  id           Int       @id @default(autoincrement())
  employee_id  Int
  user_id      Int?
  type         String    // "clock_in" | "clock_out"
  timestamp    DateTime  @default(now())
  photo_url    String?   @db.Text
  latitude     Float?
  longitude    Float?
  address      String?   @db.Text
  remarks      String?   @db.Text
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  employee Employee @relation(fields: [employee_id], references: [id])

  @@map("employee_attendances")
}

// ══════════════════════════════════════════════════════════════
// Employee Leave (員工請假)
// ══════════════════════════════════════════════════════════════

model EmployeeLeave {
  id           Int       @id @default(autoincrement())
  employee_id  Int
  user_id      Int?
  leave_type   String    // "sick" | "annual"
  date_from    DateTime  @db.Date
  date_to      DateTime  @db.Date
  days         Float     @default(1)
  reason       String?   @db.Text
  status       String    @default("pending") // "pending" | "approved" | "rejected"
  approved_by  Int?
  approved_at  DateTime?
  remarks      String?   @db.Text
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  employee Employee @relation(fields: [employee_id], references: [id])

  @@map("employee_leaves")
}

// ══════════════════════════════════════════════════════════════
// Expense Categories (支出類別 – 大類別/子類別)
// ══════════════════════════════════════════════════════════════

model ExpenseCategory {
  id         Int      @id @default(autoincrement())
  name       String
  parent_id  Int?
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  parent   ExpenseCategory?  @relation("category_hierarchy", fields: [parent_id], references: [id], onDelete: Cascade)
  children ExpenseCategory[] @relation("category_hierarchy")
  expenses Expense[]

  @@map("expense_categories")
}

// ══════════════════════════════════════════════════════════════
// Expenses (支出)
// ══════════════════════════════════════════════════════════════

model Expense {
  id                 Int       @id @default(autoincrement())
  date               DateTime  @db.Date
  company_id         Int?
  supplier_name      String?
  supplier_partner_id Int?
  category_id        Int?
  employee_id        Int?
  item               String?
  total_amount       Decimal   @default(0) @db.Decimal(12, 2)
  is_paid            Boolean   @default(false)
  payment_method     String?
  payment_date       DateTime? @db.Date
  payment_ref        String?
  remarks            String?   @db.Text
  machine_code       String?
  machinery_id       Int?
  client_id          Int?
  contract_id        Int?
  project_id         Int?
  quotation_id       Int?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now()) @updatedAt

  company     Company?         @relation(fields: [company_id], references: [id])
  supplier    Partner?         @relation("expense_supplier", fields: [supplier_partner_id], references: [id])
  category    ExpenseCategory? @relation(fields: [category_id], references: [id])
  employee    Employee?        @relation(fields: [employee_id], references: [id])
  machinery   Machinery?       @relation(fields: [machinery_id], references: [id])
  client      Partner?         @relation("expense_client", fields: [client_id], references: [id])
  contract    Contract?        @relation(fields: [contract_id], references: [id])
  project     Project?         @relation(fields: [project_id], references: [id])
  quotation   Quotation?       @relation(fields: [quotation_id], references: [id])
  items       ExpenseItem[]
  attachments ExpenseAttachment[]

  @@map("expenses")
}

// ══════════════════════════════════════════════════════════════
// Expense Items (支出細項)
// ══════════════════════════════════════════════════════════════

model ExpenseItem {
  id          Int     @id @default(autoincrement())
  expense_id  Int
  description String
  quantity    Decimal @default(1)  @db.Decimal(10, 3)
  unit_price  Decimal @default(0)  @db.Decimal(12, 2)
  amount      Decimal @default(0)  @db.Decimal(12, 2)
  sort_order  Int     @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  expense Expense @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  @@map("expense_items")
}

// ══════════════════════════════════════════════════════════════
// Expense Attachments (支出附件)
// ══════════════════════════════════════════════════════════════

model ExpenseAttachment {
  id           Int      @id @default(autoincrement())
  expense_id   Int
  file_name    String
  file_url     String
  file_size    Int?     // bytes
  mime_type    String?
  uploaded_at  DateTime @default(now())

  expense Expense @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  @@map("expense_attachments")
}
