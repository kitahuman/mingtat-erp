// ══════════════════════════════════════════════════════════════
// Work Logs
// ══════════════════════════════════════════════════════════════

model WorkLog {
  id                     Int       @id @default(autoincrement())
  publisher_id           Int?
  status                 String    @default("editing")
  service_type           String?
  scheduled_date         DateTime? @db.Date
  company_profile_id     Int?
  company_id             Int?
  client_id              Int?
  quotation_id           Int?
  contract_id            Int?
  client_contract_no     String?
  employee_id            Int?
  machine_type           String?
  equipment_number       String?
  equipment_source       String?
  tonnage                String?
  day_night              String?
  start_location         String?   @db.Text
  start_time             String?
  end_location           String?   @db.Text
  end_time               String?
  quantity               Decimal?  @db.Decimal(10, 2)
  unit                   String?
  ot_quantity            Decimal?  @db.Decimal(10, 2)
  ot_unit                String?
  is_mid_shift           Boolean   @default(false)
  goods_quantity         Decimal?  @db.Decimal(10, 2)
  matched_rate_card_id   Int?
  matched_rate           Decimal?  @db.Decimal(12, 2)
  matched_unit           String?
  matched_ot_rate        Decimal?  @db.Decimal(12, 2)
  price_match_status     String?
  price_match_note       String?   @db.Text
  receipt_no             String?
  work_order_no          String?
  is_confirmed           Boolean   @default(false)
  is_paid                Boolean   @default(false)
  unverified_client_name String? // 員工自行輸入的未確認客戶名
  source                 String    @default("manual") // manual | whatsapp | report
  is_location_new        Boolean   @default(false) // WhatsApp 來源新建地點，待管理員確認
  ai_parsed_data         Json? // AI 原始解析結果（WhatsApp 打卡）
  work_content           String?   @db.Text // 工作內容（工程部工作性質、機械部工作內容）
  work_log_product_name  String?   @db.Text // 商品名稱
  work_log_product_unit  String?   @db.Text // 商品單位（從 field_options product_unit 選擇）
  work_log_photo_urls    Json?     @db.JsonB // ["url1", "url2", ...] 員工上傳的相片 URL
  work_log_signature_url String?   @db.Text // 員工簽名圖片 URL
  remarks                String?   @db.Text
  created_at             DateTime  @default(now())
  updated_at             DateTime  @default(now()) @updatedAt
  deleted_at             DateTime? // 軯刪除時間時戳
  deleted_by             Int?
  deletedBy              User?     @relation("WorkLogDeletedBy", fields: [deleted_by], references: [id])

  project_id               Int?
  work_log_fleet_driver_id Int?

  publisher                  User?                      @relation(fields: [publisher_id], references: [id])
  company_profile            CompanyProfile?            @relation(fields: [company_profile_id], references: [id])
  company                    Company?                   @relation(fields: [company_id], references: [id])
  client                     Partner?                   @relation(fields: [client_id], references: [id])
  quotation                  Quotation?                 @relation(fields: [quotation_id], references: [id])
  contract                   Contract?                  @relation(fields: [contract_id], references: [id])
  employee                   Employee?                  @relation(fields: [employee_id], references: [id])
  project                    Project?                   @relation(fields: [project_id], references: [id])
  fleet_driver               SubcontractorFleetDriver?  @relation(fields: [work_log_fleet_driver_id], references: [id])
  payroll_work_logs          PayrollWorkLog[]
  whatsapp_messages          WhatsAppMessage[]
  verification_confirmations VerificationConfirmation[]
  attendance_anomalies       AttendanceAnomaly[]
  subcon_payroll_items       SubconPayrollItem[]
  // ── Performance indexes ──
  @@index([scheduled_date])
  @@index([employee_id])
  @@index([company_id])
  @@index([client_id])
  @@index([contract_id])
  @@index([quotation_id])
  @@index([project_id])
  @@index([status])
  @@index([is_confirmed])
  @@index([is_paid])
  @@index([deleted_at])
  @@index([company_profile_id])
  @@index([equipment_number])
  @@index([scheduled_date, employee_id])
  @@index([scheduled_date, company_id])
  @@map("work_logs")
}

