// ══════════════════════════════════════════════════════════════
// Expense Categories (支出類別 – 大類別/子類別)
// ══════════════════════════════════════════════════════════════

model ExpenseCategory {
  id         Int      @id @default(autoincrement())
  name       String
  parent_id  Int?
  type       String?  @db.VarChar(20) // DIRECT | OVERHEAD
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  parent   ExpenseCategory?  @relation("category_hierarchy", fields: [parent_id], references: [id], onDelete: Cascade)
  children ExpenseCategory[] @relation("category_hierarchy")
  expenses Expense[]

  @@map("expense_categories")
}

// ══════════════════════════════════════════════════════════════
// Expenses (支出)
// ══════════════════════════════════════════════════════════════

model Expense {
  id                  Int       @id @default(autoincrement())
  date                DateTime  @db.Date
  company_id          Int?
  supplier_name       String?
  supplier_partner_id Int?
  category_id         Int?
  employee_id         Int?
  item                String?
  total_amount        Decimal   @default(0) @db.Decimal(12, 2)
  is_paid             Boolean   @default(false)
  payment_method      String?
  payment_date        DateTime? @db.Date
  payment_ref         String?
  remarks             String?   @db.Text
  source              String?   @default("MANUAL") // MANUAL | PURCHASE | PAYROLL | SUBCON | CONTRA
  source_ref_id       Int? // 關聯到來源記錄的 ID
  machine_code        String?
  machinery_id        Int?
  client_id           Int?
  contract_id         Int?
  project_id          Int?
  quotation_id        Int?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  company     Company?            @relation(fields: [company_id], references: [id])
  supplier    Partner?            @relation("expense_supplier", fields: [supplier_partner_id], references: [id])
  category    ExpenseCategory?    @relation(fields: [category_id], references: [id])
  employee    Employee?           @relation(fields: [employee_id], references: [id])
  machinery   Machinery?          @relation(fields: [machinery_id], references: [id])
  client      Partner?            @relation("expense_client", fields: [client_id], references: [id])
  contract    Contract?           @relation(fields: [contract_id], references: [id])
  project     Project?            @relation(fields: [project_id], references: [id])
  quotation   Quotation?          @relation(fields: [quotation_id], references: [id])
  items       ExpenseItem[]
  attachments ExpenseAttachment[]

  // Phase 4
  payment_outs PaymentOut[]

  @@map("expenses")
}

// ══════════════════════════════════════════════════════════════
// Expense Items (支出細項)
// ══════════════════════════════════════════════════════════════

model ExpenseItem {
  id          Int      @id @default(autoincrement())
  expense_id  Int
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unit_price  Decimal  @default(0) @db.Decimal(12, 2)
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  expense Expense @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  @@map("expense_items")
}

// ══════════════════════════════════════════════════════════════
// Expense Attachments (支出附件)
// ══════════════════════════════════════════════════════════════

model ExpenseAttachment {
  id          Int      @id @default(autoincrement())
  expense_id  Int
  file_name   String
  file_url    String
  file_size   Int? // bytes
  mime_type   String?
  uploaded_at DateTime @default(now())

  expense Expense @relation(fields: [expense_id], references: [id], onDelete: Cascade)

  @@map("expense_attachments")
}

// ══════════════════════════════════════════════════════════════
// Phase 3: Payment Application (IPA / 計糧)
// ══════════════════════════════════════════════════════════════

model PaymentApplication {
  id                 Int       @id @default(autoincrement())
  contract_id        Int
  project_id         Int?
  pa_no              Int
  reference          String    @db.VarChar(100)
  period_from        DateTime? @db.Date
  period_to          DateTime  @db.Date
  submission_date    DateTime? @db.Date
  certification_date DateTime? @db.Date
  payment_due_date   DateTime? @db.Date

  // 金額欄位（後端自動計算）
  bq_work_done          Decimal @default(0) @db.Decimal(14, 2) // (A)
  vo_work_done          Decimal @default(0) @db.Decimal(14, 2) // (B)
  cumulative_work_done  Decimal @default(0) @db.Decimal(14, 2) // (C) = A + B
  materials_on_site     Decimal @default(0) @db.Decimal(14, 2) // (D)
  gross_amount          Decimal @default(0) @db.Decimal(14, 2) // (E) = C + D
  retention_amount      Decimal @default(0) @db.Decimal(14, 2) // (F)
  after_retention       Decimal @default(0) @db.Decimal(14, 2) // (G) = E - F
  other_deductions      Decimal @default(0) @db.Decimal(14, 2) // (H)
  certified_amount      Decimal @default(0) @db.Decimal(14, 2) // (I) = G - H
  prev_certified_amount Decimal @default(0) @db.Decimal(14, 2) // (J)
  current_due           Decimal @default(0) @db.Decimal(14, 2) // (K) = I - J

  // 客戶認證金額（可能與申請金額不同）
  client_certified_amount Decimal? @db.Decimal(14, 2)
  client_current_due      Decimal? @db.Decimal(14, 2)

  // 付款追蹤
  paid_amount Decimal   @default(0) @db.Decimal(14, 2)
  paid_date   DateTime? @db.Date

  status     String   @default("draft") @db.VarChar(20)
  remarks    String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  contract    Contract            @relation(fields: [contract_id], references: [id], onDelete: Restrict)
  project     Project?            @relation(fields: [project_id], references: [id], onDelete: SetNull)
  bq_progress PaymentBqProgress[]
  vo_progress PaymentVoProgress[]
  deductions  PaymentDeduction[]
  materials   PaymentMaterial[]

  // Phase 6
  retention_tracking RetentionTracking?

  @@unique([contract_id, pa_no])
  @@map("payment_applications")
}

model PaymentBqProgress {
  id                     Int      @id @default(autoincrement())
  payment_application_id Int
  bq_item_id             Int
  prev_cumulative_qty    Decimal  @default(0) @db.Decimal(14, 4)
  current_cumulative_qty Decimal  @default(0) @db.Decimal(14, 4)
  this_period_qty        Decimal  @default(0) @db.Decimal(14, 4)
  unit_rate              Decimal  @default(0) @db.Decimal(14, 2)
  prev_cumulative_amount Decimal  @default(0) @db.Decimal(14, 2)
  current_amount         Decimal  @default(0) @db.Decimal(14, 2)
  this_period_amount     Decimal  @default(0) @db.Decimal(14, 2)
  remarks                String?  @db.Text
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now()) @updatedAt

  payment_application PaymentApplication @relation(fields: [payment_application_id], references: [id], onDelete: Cascade)
  bq_item             ContractBqItem     @relation(fields: [bq_item_id], references: [id], onDelete: Restrict)

  @@unique([payment_application_id, bq_item_id])
  @@map("payment_bq_progress")
}

model PaymentVoProgress {
  id                     Int      @id @default(autoincrement())
  payment_application_id Int
  vo_item_id             Int
  prev_cumulative_qty    Decimal  @default(0) @db.Decimal(14, 4)
  current_cumulative_qty Decimal  @default(0) @db.Decimal(14, 4)
  this_period_qty        Decimal  @default(0) @db.Decimal(14, 4)
  unit_rate              Decimal  @default(0) @db.Decimal(14, 2)
  prev_cumulative_amount Decimal  @default(0) @db.Decimal(14, 2)
  current_amount         Decimal  @default(0) @db.Decimal(14, 2)
  this_period_amount     Decimal  @default(0) @db.Decimal(14, 2)
  remarks                String?  @db.Text
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now()) @updatedAt

  payment_application PaymentApplication @relation(fields: [payment_application_id], references: [id], onDelete: Cascade)
  vo_item             VariationOrderItem @relation(fields: [vo_item_id], references: [id], onDelete: Restrict)

  @@unique([payment_application_id, vo_item_id])
  @@map("payment_vo_progress")
}

model PaymentDeduction {
  id                     Int      @id @default(autoincrement())
  payment_application_id Int
  deduction_type         String   @db.VarChar(50)
  description            String   @db.VarChar(500)
  amount                 Decimal  @default(0) @db.Decimal(14, 2)
  remarks                String?  @db.Text
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now()) @updatedAt

  payment_application PaymentApplication @relation(fields: [payment_application_id], references: [id], onDelete: Cascade)

  @@map("payment_deductions")
}

model PaymentMaterial {
  id                     Int      @id @default(autoincrement())
  payment_application_id Int
  description            String   @db.VarChar(500)
  amount                 Decimal  @default(0) @db.Decimal(14, 2)
  remarks                String?  @db.Text
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now()) @updatedAt

  payment_application PaymentApplication @relation(fields: [payment_application_id], references: [id], onDelete: Cascade)

  @@map("payment_materials")
}

// ══════════════════════════════════════════════════════════════
// Phase 4: PaymentIn (收款記錄)
// ══════════════════════════════════════════════════════════════

model PaymentIn {
  id            Int      @id @default(autoincrement())
  date          DateTime @db.Date
  amount        Decimal  @db.Decimal(14, 2)
  source_type   String   @db.VarChar(30) // payment_certificate | invoice | retention_release | other
  source_ref_id Int? // 關聯 ID（PaymentApplication.id / RetentionRelease.id 等）
  project_id    Int?
  contract_id   Int?
  bank_account  String?  @db.VarChar(100)
  reference_no  String?  @db.VarChar(100) // 支票號碼 / 交易號碼
  remarks       String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  project  Project?  @relation(fields: [project_id], references: [id], onDelete: SetNull)
  contract Contract? @relation(fields: [contract_id], references: [id], onDelete: SetNull)

  @@map("payment_ins")
}

// ══════════════════════════════════════════════════════════════
// Phase 4: PaymentOut (付款記錄)
// ══════════════════════════════════════════════════════════════

model PaymentOut {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  amount       Decimal  @db.Decimal(14, 2)
  expense_id   Int?
  project_id   Int?
  bank_account String?  @db.VarChar(100)
  reference_no String?  @db.VarChar(100) // 支票號碼 / 交易號碼
  remarks      String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt

  expense Expense? @relation(fields: [expense_id], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)

  @@map("payment_outs")
}

// ══════════════════════════════════════════════════════════════
// Phase 5: Invoice (發票 - 簡單項目用)
// ══════════════════════════════════════════════════════════════

model Invoice {
  id                 Int       @id @default(autoincrement())
  invoice_no         String    @unique
  date               DateTime  @db.Date
  due_date           DateTime? @db.Date
  client_id          Int?
  project_id         Int?
  quotation_id       Int?
  company_id         Int
  invoice_title      String? // 發票名稱/標題
  client_contract_no String? // 客戶合約編號
  status             String    @default("draft") @db.VarChar(30) // draft | issued | partially_paid | paid | void
  subtotal           Decimal   @default(0) @db.Decimal(14, 2)
  tax_rate           Decimal   @default(0) @db.Decimal(5, 2) // kept for backward compat
  tax_amount         Decimal   @default(0) @db.Decimal(14, 2) // kept for backward compat
  retention_rate     Decimal   @default(0) @db.Decimal(5, 2) // 保留金百分比
  retention_amount   Decimal   @default(0) @db.Decimal(14, 2) // 保留金金額
  other_charges      Json?     @db.JsonB // [{name, amount}] 其他費用
  total_amount       Decimal   @default(0) @db.Decimal(14, 2)
  paid_amount        Decimal   @default(0) @db.Decimal(14, 2)
  outstanding        Decimal   @default(0) @db.Decimal(14, 2)
  payment_terms      String?   @db.Text
  remarks            String?   @db.Text
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now()) @updatedAt

  client    Partner?      @relation("invoice_client", fields: [client_id], references: [id], onDelete: SetNull)
  project   Project?      @relation(fields: [project_id], references: [id], onDelete: SetNull)
  quotation Quotation?    @relation(fields: [quotation_id], references: [id], onDelete: SetNull)
  company   Company       @relation(fields: [company_id], references: [id])
  items     InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoice_id  Int
  sort_order  Int     @default(1)
  item_name   String? // 項目標題 (like QuotationItem.item_name)
  description String? @db.Text // 項目描述
  quantity    Decimal @default(0) @db.Decimal(12, 4)
  unit        String?
  unit_price  Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model InvoiceSequence {
  id         Int    @id @default(autoincrement())
  prefix     String
  year_month String
  last_seq   Int    @default(0)

  @@unique([prefix, year_month])
  @@map("invoice_sequences")
}

// ══════════════════════════════════════════════════════════════
// Phase 6: RetentionTracking (扣留金追蹤)
// ══════════════════════════════════════════════════════════════

model RetentionTracking {
  id                     Int      @id @default(autoincrement())
  contract_id            Int
  payment_application_id Int      @unique
  pa_no                  Int // 第幾期
  retention_amount       Decimal  @db.Decimal(14, 2) // 本期扣留金額
  cumulative_retention   Decimal  @db.Decimal(14, 2) // 累計扣留金
  remarks                String?  @db.Text
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now()) @updatedAt

  contract            Contract           @relation(fields: [contract_id], references: [id], onDelete: Restrict)
  payment_application PaymentApplication @relation(fields: [payment_application_id], references: [id], onDelete: Cascade)

  @@unique([contract_id, payment_application_id])
  @@map("retention_trackings")
}

// ══════════════════════════════════════════════════════════════
// Phase 6: RetentionRelease (扣留金釋放)
// ══════════════════════════════════════════════════════════════

model RetentionRelease {
  id            Int      @id @default(autoincrement())
  contract_id   Int
  release_date  DateTime @db.Date
  amount        Decimal  @db.Decimal(14, 2)
  reason        String   @db.VarChar(200) // pc_release | dlp_release | other
  description   String?  @db.Text
  payment_in_id Int? // 自動建立的 PaymentIn ID
  status        String   @default("pending") @db.VarChar(20) // pending | approved | paid
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  contract Contract @relation(fields: [contract_id], references: [id], onDelete: Restrict)

  @@map("retention_releases")
}

// ══════════════════════════════════════════════════════════════
// Phase 9: BankAccount (銀行帳戶)
// ══════════════════════════════════════════════════════════════

model BankAccount {
  id           Int      @id @default(autoincrement())
  account_name String   @db.VarChar(200) // 帳戶名稱
  bank_name    String   @db.VarChar(200) // 銀行名稱
  account_no   String   @db.VarChar(100) // 帳號
  currency     String   @default("HKD") @db.VarChar(10) // 幣種
  is_active    Boolean  @default(true)
  remarks      String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt

  transactions BankTransaction[]

  @@map("bank_accounts")
}

// ══════════════════════════════════════════════════════════════
// Phase 9: BankTransaction (銀行交易記錄)
// ══════════════════════════════════════════════════════════════

model BankTransaction {
  id              Int      @id @default(autoincrement())
  bank_account_id Int
  date            DateTime @db.Date
  description     String   @db.Text
  amount          Decimal  @db.Decimal(14, 2) // 正數=存入(Credit)，負數=支出(Debit)
  debit_credit    String   @db.VarChar(10) // debit | credit
  balance         Decimal? @db.Decimal(14, 2) // 餘額（如 CSV 有提供）
  reference_no    String?  @db.VarChar(200) // 支票號碼/交易號碼
  match_status    String   @default("unmatched") @db.VarChar(20) // unmatched | matched | excluded
  matched_type    String?  @db.VarChar(30) // payment_in | payment_out
  matched_id      Int? // 配對的 PaymentIn.id 或 PaymentOut.id
  import_batch    String?  @db.VarChar(100) // 匯入批次識別
  remarks         String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  bank_account BankAccount @relation(fields: [bank_account_id], references: [id], onDelete: Restrict)

  @@index([bank_account_id, date])
  @@index([match_status])
  @@map("bank_transactions")
}

// ══════════════════════════════════════════════════════════════
// Verification Module: 工作紀錄核對
// ══════════════════════════════════════════════════════════════

// 1. verification_source — 核對來源定義
model VerificationSource {
  id                     Int      @id @default(autoincrement())
  source_code            String   @unique @db.VarChar(50)
  source_name            String   @db.VarChar(100)
  source_type            String   @db.VarChar(20) // excel | ocr | system | gps | webhook
  source_description     String?  @db.Text
  source_file_format     String?  @db.VarChar(100)
  source_expected_fields Int?
  source_is_active       Boolean  @default(true)
  source_created_at      DateTime @default(now())
  source_updated_at      DateTime @default(now()) @updatedAt

  batches     VerificationBatch[]
  records     VerificationRecord[]
  matches     VerificationMatch[]
  ocr_results VerificationOcrResult[]

  @@map("verification_sources")
}

// 2. verification_batch — 匯入批次
model VerificationBatch {
  id                            Int       @id @default(autoincrement())
  batch_code                    String    @unique @db.VarChar(100)
  batch_source_id               Int
  batch_file_name               String?   @db.VarChar(255)
  batch_file_size               BigInt?
  batch_file_hash               String?   @db.VarChar(64)
  batch_upload_user_id          Int?
  batch_upload_time             DateTime  @default(now())
  batch_period_year             Int?
  batch_period_month            Int?
  batch_total_rows              Int?
  batch_filtered_rows           Int?
  batch_status                  String    @default("pending") @db.VarChar(20) // pending | imported | processing | matched | completed | failed | cancelled
  batch_error_message           String?   @db.Text
  batch_processing_started_at   DateTime?
  batch_processing_completed_at DateTime?
  batch_notes                   String?   @db.Text

  source        VerificationSource       @relation(fields: [batch_source_id], references: [id])
  records       VerificationRecord[]
  gps_summaries VerificationGpsSummary[]
  ocr_results   VerificationOcrResult[]

  @@index([batch_source_id])
  @@index([batch_upload_time])
  @@index([batch_period_year, batch_period_month])
  @@map("verification_batches")
}

// 3. verification_record — 匯入記錄（逐筆資料）
model VerificationRecord {
  id                       Int       @id @default(autoincrement())
  record_batch_id          Int
  record_source_id         Int
  record_source_row_number Int?
  record_work_date         DateTime? @db.Date
  record_vehicle_no        String?   @db.VarChar(50)
  record_driver_name       String?   @db.VarChar(100)
  record_customer          String?   @db.VarChar(100)
  record_location_from     String?   @db.VarChar(200)
  record_location_to       String?   @db.VarChar(200)
  record_time_in           DateTime? @db.Time()
  record_time_out          DateTime? @db.Time()
  record_contract_no       String?   @db.VarChar(50)
  record_slip_no           String?   @db.VarChar(50)
  record_quantity          String?   @db.VarChar(50)
  record_weight_net        Decimal?  @db.Decimal(10, 2)
  record_employee_id       Int?
  record_employee_name     String?   @db.VarChar(100)
  record_raw_data          Json?
  record_ocr_confidence    Decimal?  @db.Decimal(5, 2)
  record_created_at        DateTime  @default(now())

  batch   VerificationBatch        @relation(fields: [record_batch_id], references: [id])
  source  VerificationSource       @relation(fields: [record_source_id], references: [id])
  chits   VerificationRecordChit[]
  matches VerificationMatch[]

  @@index([record_batch_id])
  @@index([record_vehicle_no])
  @@index([record_work_date])
  @@index([record_slip_no])
  @@index([record_driver_name])
  @@index([record_employee_id])
  @@map("verification_records")
}

// 4. verification_record_chit — 記錄關聯的入帳票號碼（一對多）
model VerificationRecordChit {
  id              Int      @id @default(autoincrement())
  chit_record_id  Int
  chit_no         String   @db.VarChar(50)
  chit_seq        Int      @default(1)
  chit_created_at DateTime @default(now())

  record VerificationRecord @relation(fields: [chit_record_id], references: [id], onDelete: Cascade)

  @@unique([chit_record_id, chit_no])
  @@index([chit_record_id])
  @@index([chit_no])
  @@map("verification_record_chits")
}

// 5. verification_match — 配對結果
model VerificationMatch {
  id                    Int       @id @default(autoincrement())
  match_work_record_id  Int
  match_source_id       Int
  match_record_id       Int?
  match_status          String    @default("unverified") @db.VarChar(20) // matched | diff | missing | unverified
  match_confidence      Decimal?  @db.Decimal(5, 2)
  match_diff_fields     Json?
  match_diff_count      Int       @default(0)
  match_method          String?   @db.VarChar(30)
  match_notes           String?   @db.Text
  match_resolved_by     Int?
  match_resolved_at     DateTime?
  match_resolved_action String?   @db.VarChar(30) // confirm | override | ignore | manual_correct
  match_created_at      DateTime  @default(now())
  match_updated_at      DateTime  @default(now()) @updatedAt

  source      VerificationSource      @relation(fields: [match_source_id], references: [id])
  record      VerificationRecord?     @relation(fields: [match_record_id], references: [id])
  action_logs VerificationActionLog[]

  @@index([match_work_record_id])
  @@index([match_status])
  @@index([match_source_id])
  @@index([match_created_at])
  @@index([match_method])
  @@map("verification_matches")
}

// 6. verification_gps_summary — GPS 每日行程摘要
model VerificationGpsSummary {
  id                         Int       @id @default(autoincrement())
  gps_summary_batch_id       Int
  gps_summary_vehicle_no     String?   @db.VarChar(50)
  gps_summary_date           DateTime? @db.Date
  gps_summary_start_time     DateTime?
  gps_summary_end_time       DateTime?
  gps_summary_total_distance Decimal?  @db.Decimal(10, 2)
  gps_summary_trip_count     Int?
  gps_summary_locations      Json?
  gps_summary_raw_points     Int?
  gps_summary_ai_model       String?   @db.VarChar(50)
  gps_summary_processed_at   DateTime  @default(now())

  batch VerificationBatch @relation(fields: [gps_summary_batch_id], references: [id])

  @@index([gps_summary_vehicle_no, gps_summary_date])
  @@map("verification_gps_summaries")
}

// 7. verification_ocr_result — OCR 辨識結果
model VerificationOcrResult {
  id                     Int      @id @default(autoincrement())
  ocr_batch_id           Int
  ocr_source_id          Int
  ocr_file_name          String?  @db.VarChar(255)
  ocr_image_url          String?  @db.VarChar(500)
  ocr_extracted_data     Json?
  ocr_confidence_overall Decimal? @db.Decimal(5, 2)
  ocr_field_confidence   Json?
  ocr_engine             String   @default("gpt-vision") @db.VarChar(50)
  ocr_raw_text           String?  @db.Text
  ocr_status             String   @default("pending") @db.VarChar(20) // pending | processing | completed | failed
  ocr_image_base64       String?  @db.Text
  ocr_confirmed_data     Json?    @db.JsonB
  ocr_user_confirmed     Boolean  @default(false)
  ocr_user_corrections   Json?
  ocr_created_at         DateTime @default(now())

  batch  VerificationBatch  @relation(fields: [ocr_batch_id], references: [id])
  source VerificationSource @relation(fields: [ocr_source_id], references: [id])

  @@index([ocr_batch_id])
  @@index([ocr_status])
  @@map("verification_ocr_results")
}

// 8. verification_wa_message — WhatsApp 原始訊息
model VerificationWaMessage {
  id                   Int       @id @default(autoincrement())
  wa_msg_remote_id     String?   @db.VarChar(100)
  wa_msg_group_id      String?   @db.VarChar(100)
  wa_msg_group_name    String?   @db.VarChar(200)
  wa_msg_sender_jid    String?   @db.VarChar(100)
  wa_msg_sender_name   String?   @db.VarChar(100)
  wa_msg_timestamp     DateTime?
  wa_msg_body          String?   @db.Text
  wa_msg_type          String?   @db.VarChar(50)
  wa_msg_is_forwarded  Boolean   @default(false)
  wa_msg_has_media     Boolean   @default(false)
  wa_msg_media_url     String?   @db.VarChar(500)
  wa_msg_ai_classified String?   @db.VarChar(30) // order | chat | leave | vehicle_issue | other
  wa_msg_ai_confidence Decimal?  @db.Decimal(5, 2)
  wa_msg_processed     Boolean   @default(false)
  wa_msg_created_at    DateTime  @default(now())

  orders   VerificationWaOrder[]
  mod_logs VerificationWaModLog[]

  @@index([wa_msg_group_id])
  @@index([wa_msg_timestamp])
  @@index([wa_msg_ai_classified])
  @@index([wa_msg_remote_id])
  @@map("verification_wa_messages")
}

// 9. verification_wa_order — WhatsApp 解析後的 Order
model VerificationWaOrder {
  id                     Int      @id @default(autoincrement())
  wa_order_msg_id        Int?
  wa_order_date          DateTime @db.Date
  wa_order_status        String   @default("tentative") @db.VarChar(20) // tentative | confirmed
  wa_order_version       Int      @default(1)
  wa_order_sender_name   String?  @db.VarChar(100)
  wa_order_sender_role   String?  @db.VarChar(50)
  wa_order_raw_text      String?  @db.Text
  wa_order_item_count    Int      @default(0)
  wa_order_ai_model      String?  @db.VarChar(50)
  wa_order_ai_confidence Decimal? @db.Decimal(5, 2)
  wa_order_created_at    DateTime @default(now())

  message  VerificationWaMessage?    @relation(fields: [wa_order_msg_id], references: [id])
  items    VerificationWaOrderItem[]
  mod_logs VerificationWaModLog[]

  @@index([wa_order_date])
  @@index([wa_order_status])
  @@index([wa_order_msg_id])
  @@map("verification_wa_orders")
}

// 10. verification_wa_order_item — WhatsApp Order 工作項目
model VerificationWaOrderItem {
  id                      Int      @id @default(autoincrement())
  wa_item_order_id        Int
  wa_item_seq             Int      @default(1)
  wa_item_order_type      String?  @db.VarChar(30) // machinery | manpower | transport | notice | leave
  wa_item_contract_no     String?  @db.VarChar(50)
  wa_item_customer        String?  @db.VarChar(100)
  wa_item_work_desc       String?  @db.VarChar(500)
  wa_item_location        String?  @db.VarChar(200)
  wa_item_driver_nickname String?  @db.VarChar(50)
  wa_item_driver_id       Int?
  wa_item_vehicle_no      String?  @db.VarChar(50)
  wa_item_machine_code    String?  @db.VarChar(50)
  wa_item_contact_person  String?  @db.VarChar(200)
  wa_item_slip_write_as   String?  @db.VarChar(100)
  wa_item_is_suspended    Boolean  @default(false)
  wa_item_remarks         String?  @db.Text
  wa_item_mod_status      String?  @db.VarChar(30) // cancelled | reassigned | suspended | added | null(unmodified)
  wa_item_mod_prev_data   Json?    // snapshot of previous values before modification
  wa_item_created_at      DateTime @default(now())

  order          VerificationWaOrder          @relation(fields: [wa_item_order_id], references: [id], onDelete: Cascade)
  mod_logs       VerificationWaModLog[]       @relation("ModLogItem")

  @@index([wa_item_order_id])
  @@index([wa_item_driver_nickname])
  @@index([wa_item_vehicle_no])
  @@index([wa_item_contract_no])
  @@map("verification_wa_order_items")
}

// 10b. verification_wa_mod_logs — WhatsApp Order 修改歷史
model VerificationWaModLog {
  id                  Int      @id @default(autoincrement())
  mod_order_id        Int
  mod_item_id         Int?
  mod_msg_id          Int
  mod_type            String   @db.VarChar(30) // cancel | reassign | suspend | resume | add | other
  mod_description     String   @db.Text
  mod_prev_value      Json?    // previous values snapshot
  mod_new_value       Json?    // new values snapshot
  mod_ai_confidence   Decimal? @db.Decimal(5, 2)
  mod_created_at      DateTime @default(now())

  order   VerificationWaOrder      @relation(fields: [mod_order_id], references: [id], onDelete: Cascade)
  item    VerificationWaOrderItem? @relation("ModLogItem", fields: [mod_item_id], references: [id], onDelete: SetNull)
  message VerificationWaMessage    @relation(fields: [mod_msg_id], references: [id], onDelete: Cascade)

  @@index([mod_order_id])
  @@index([mod_item_id])
  @@index([mod_msg_id])
  @@map("verification_wa_mod_logs")
}

// 11. verification_nickname_mapping — 花名對照表
model VerificationNicknameMapping {
  id                     Int      @id @default(autoincrement())
  nickname_value         String   @db.VarChar(50)
  nickname_employee_id   Int?
  nickname_employee_name String?  @db.VarChar(100)
  nickname_vehicle_no    String?  @db.VarChar(50)
  nickname_is_active     Boolean  @default(true)
  nickname_created_at    DateTime @default(now())
  nickname_updated_at    DateTime @default(now()) @updatedAt

  @@index([nickname_value])
  @@index([nickname_employee_id])
  @@map("verification_nickname_mappings")
}

// 12. verification_action_log — 操作日誌
model VerificationActionLog {
  id              Int      @id @default(autoincrement())
  log_user_id     Int
  log_user_name   String?  @db.VarChar(100)
  log_action_type String   @db.VarChar(30) // confirm | override | ignore | manual_correct | batch_action
  log_match_id    Int?
  log_old_status  String?  @db.VarChar(50)
  log_new_status  String?  @db.VarChar(50)
  log_details     Json?
  log_ip_address  String?  @db.VarChar(50)
  log_created_at  DateTime @default(now())

  match VerificationMatch? @relation(fields: [log_match_id], references: [id])

  @@index([log_user_id])
  @@index([log_match_id])
  @@index([log_created_at])
  @@map("verification_action_logs")
}
